#!/usr/bin/env bash

# Power menu options
options=(
    "Shutdown"
    "Reboot"
    "Lock"
    "Suspend"
   "Logout"
)

# Show Rofi with two columns, no input bar, and large font
choice="$(printf '%s\n' "${options[@]}" | rofi -dmenu -i -p '')"
case "$choice" in
    "Shutdown")
        systemctl poweroff
        ;;
    "Reboot")
        systemctl reboot
        ;;
    "Lock")
        if command -v hyprlock >/dev/null; then
            hyprlock
        else
            notify-send "No lock utility found."
        fi
        ;;
    "Suspend")
        systemctl suspend
        ;;
    "Logout")
            pkill -KILL -u "$USER"
        ;;
esac
